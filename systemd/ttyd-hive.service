[Unit]
Description=ttyd web terminal for hive agent sessions
After=network.target

[Service]
Type=simple
User=dev
# Access ttyd via SSH tunnel or authenticated reverse proxy only
ExecStart=/usr/bin/ttyd -W -i 127.0.0.1 -p 7681 -t fontSize=14 -t disableLeaveAlert=true /usr/local/bin/ttyd-tmux.sh
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
